generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Department {
  id      String   @id @default(uuid())
  code    String   @unique
  name    String
  careers Career[]
  courses Course[]

  @@map("departments")
}

model Career {
  id           String     @id @default(uuid())
  code         String     @unique
  name         String
  departmentId String     @map("department_id")
  department   Department @relation(fields: [departmentId], references: [id])
  users        User[]

  @@map("careers")
}

model User {
  email                   String               @unique
  name                    String
  isEmailVerified         Boolean              @default(false) @map("is_email_verified")
  verificationToken       String?              @map("verification_token")
  resetToken              String?              @map("reset_token")
  resetTokenExpiry        DateTime?            @map("reset_token_expiry")
  otpCode                 String?              @map("otp_code")
  otpCodeExpiry           DateTime?            @map("otp_code_expiry")
  createdAt               DateTime             @default(now()) @map("created_at")
  updatedAt               DateTime             @updatedAt @map("updated_at")
  careerId                String?              @map("career_id")
  isActive                Boolean              @default(true) @map("is_active")
  isTutorApproved         Boolean              @default(false) @map("is_tutor_approved")
  isTutorRequested        Boolean              @default(false) @map("is_tutor_requested")
  passwordHash            String?              @map("password_hash")
  phoneNumber             String?              @map("phone_number")
  profilePictureUrl       String?              @map("profile_picture_url")
  id                      String               @id @default(uuid())
  authProvider            AuthProviderEnum     @default(Local) @map("auth_provider")
  googleId                String?              @unique @map("google_id")
  terms                   Boolean              @default(false)
  role                    Role                 @default(STUDENT)
  suspendedAt             DateTime?            @map("suspended_at")
  suspendedReason         String?              @map("suspended_reason")
  suspendedById           String?              @map("suspended_by_id")
  verificationTokenExpiry DateTime?            @map("verification_token_expiry")
  lastSeenAt              DateTime?            @map("last_seen_at")
  studentRating           Decimal              @default(0) @map("student_rating") @db.Decimal(3, 2)
  studentRatingCount      Int                  @default(0) @map("student_rating_count")
  otpAttempts             Int                  @default(0) @map("otp_attempts")
  adminActions            AdminAuditLog[]      @relation("AdminActor")
  availabilities          Availability[]
  notifications           Notification[]
  paymentsAsStudent       Payment[]            @relation("PaymentsStudent")
  paymentsAsTutor         Payment[]            @relation("PaymentsTutor")
  reviewsWritten          Review[]             @relation("ReviewsWritten")
  reviewsReceived         Review[]             @relation("ReviewsReceived")
  schedule                Schedule?            @relation("UserSchedule")
  participations          SessionParticipant[]
  tutorSessions           Session[]            @relation("TutorSessions")
  studentReviewsReceived  StudentReview[]      @relation("StudentReviewsReceived")
  studentReviewsWritten   StudentReview[]      @relation("StudentReviewsWritten")
  applicationsReviewed    TutorApplication[]   @relation("ApplicationReviewedBy")
  tutorApplications       TutorApplication[]
  tutorProfile            TutorProfile?
  career                  Career?              @relation(fields: [careerId], references: [id])
  suspendedBy             User?                @relation("UserSuspendedBy", fields: [suspendedById], references: [id])
  suspendedUsers          User[]               @relation("UserSuspendedBy")

  @@map("users")
}

model TutorProfile {
  userId                String        @id @map("user_id")
  schoolEmail           String        @unique @map("school_email")
  experienceYears       Int?          @map("experience_years")
  credits               Int           @default(0)
  experienceDescription String?       @map("experience_description")
  updatedAt             DateTime      @updatedAt @map("updated_at")
  review                Decimal       @default(0) @db.Decimal(3, 2)
  numReview             Int           @default(0) @map("num_review")
  numSessions           Int           @default(0) @map("num_sessions")
  nextPayment           Decimal       @default(0) @map("next_payment") @db.Decimal(12, 2)
  totalEarning          Decimal       @default(0) @map("total_earning") @db.Decimal(12, 2)
  bio                   String?       @map("bio") @db.VarChar(200)
  llave                 String?
  tutorCourses          TutorCourse[]
  user                  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tutor_profiles")
}

model Course {
  id           String         @id @default(uuid())
  name         String
  code         String         @unique
  basePrice    Decimal        @map("base_price") @db.Decimal(10, 2)
  complexity   ComplexityEnum
  departmentId String?        @map("department_id")
  aliases      String[]       @default([])
  coursePrice  CoursePrice?
  department   Department?    @relation(fields: [departmentId], references: [id])
  reviews      Review[]
  sessions     Session[]
  topics       Topic[]
  tutorCourses TutorCourse[]

  @@map("courses")
}

model CoursePrice {
  id        String   @id @default(uuid())
  courseId  String   @unique @map("course_id")
  price     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("course_prices")
}

model Topic {
  id          String  @id @default(uuid())
  courseId    String  @map("course_id")
  name        String
  description String?
  course      Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("topics")
}

model TutorCourse {
  tutorId       String                @map("tutor_id")
  courseId      String                @map("course_id")
  experience    String?               @map("experience")
  workSampleUrl String?               @map("work_sample_url")
  status        TutorCourseStatusEnum @default(Pending)
  course        Course                @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tutor         TutorProfile          @relation(fields: [tutorId], references: [userId], onDelete: Cascade)

  @@id([tutorId, courseId])
  @@map("tutor_courses")
}

model Schedule {
  id                String  @id @default(uuid())
  userId            String  @unique @map("user_id")
  timezone          String  @default("America/Bogota")
  autoAcceptSession Boolean @default(false) @map("auto_accept_session")
  minBookingNotice  Int     @default(24) @map("min_booking_notice")
  maxSessionsPerDay Int     @default(5) @map("max_sessions_per_day")
  bufferTime        Int     @default(15) @map("buffer_time")
  user              User    @relation("UserSchedule", fields: [userId], references: [id], onDelete: Cascade)

  @@map("schedules")
}

model Availability {
  id           String    @id @default(uuid())
  dayOfWeek    Int       @map("day_of_week")
  endTime      DateTime  @map("end_time") @db.Time(6)
  startTime    DateTime  @map("start_time") @db.Time(6)
  userId       String    @map("user_id")
  label        String?   @map("label") @db.VarChar(160)
  recurring    Boolean   @default(true) @map("recurring")
  specificDate DateTime? @map("specific_date") @db.Date
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("availabilities")
}

model Session {
  id                    String               @id @default(uuid())
  courseId              String               @map("course_id")
  tutorId               String               @map("tutor_id")
  sessionType           SessionTypeEnum      @map("session_type")
  maxCapacity           Int                  @default(1) @map("max_capacity")
  startTimestamp        DateTime             @map("start_timestamp")
  endTimestamp          DateTime             @map("end_timestamp")
  status                SessionStatusEnum    @default(Pending)
  locationType          LocationTypeEnum     @map("location_type")
  notes                 String?
  createdAt             DateTime             @default(now()) @map("created_at")
  googleCalendarEventId String?              @map("google_calendar_event_id")
  googleMeetLink        String?              @map("google_meet_link")
  cancellationReason    String?              @map("cancellation_reason")
  cancelledAt           DateTime?            @map("cancelled_at")
  cancelledBy           String?              @map("cancelled_by")
  refundMethod          String?              @map("refund_method")
  refundMethodDetails   String?              @map("refund_method_details")
  topicsToReview        String?              @map("topics_to_review")
  notifications         Notification[]
  payments              Payment[]
  reviews               Review[]
  attachments           SessionAttachment[]
  participants          SessionParticipant[]
  course                Course               @relation(fields: [courseId], references: [id])
  tutor                 User                 @relation("TutorSessions", fields: [tutorId], references: [id])
  studentReviews        StudentReview[]

  @@map("sessions")
}

model SessionAttachment {
  id         String   @id @default(uuid())
  sessionId  String   @map("session_id")
  s3Key      String   @map("s3_key")
  fileName   String   @map("file_name")
  fileSize   Int      @map("file_size")
  mimeType   String   @map("mime_type")
  uploadedAt DateTime @default(now()) @map("uploaded_at")
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("session_attachments")
}

model SessionParticipant {
  sessionId        String   @map("session_id")
  studentId        String   @map("student_id")
  joinedAt         DateTime @default(now()) @map("joined_at")
  participantCount Int      @default(1) @map("participant_count")
  session          Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student          User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([sessionId, studentId])
  @@map("session_participants")
}

model Review {
  id        String           @id @default(uuid())
  rating    Int?
  tutorId   String           @map("tutor_id")
  studentId String           @map("student_id")
  sessionId String           @map("session_id")
  comment   String?
  status    ReviewStatusEnum @default(pending)
  courseId  String           @map("course_id")
  course    Course           @relation(fields: [courseId], references: [id])
  session   Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student   User             @relation("ReviewsWritten", fields: [studentId], references: [id], onDelete: Cascade)
  tutor     User             @relation("ReviewsReceived", fields: [tutorId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId, tutorId])
  @@index([tutorId, courseId, status])
  @@map("reviews")
}

model StudentReview {
  id        String           @id @default(uuid())
  sessionId String           @map("session_id")
  tutorId   String           @map("tutor_id")
  studentId String           @map("student_id")
  rating    Int?
  status    ReviewStatusEnum @default(pending)
  comment   String?
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")
  session   Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student   User             @relation("StudentReviewsReceived", fields: [studentId], references: [id], onDelete: Cascade)
  tutor     User             @relation("StudentReviewsWritten", fields: [tutorId], references: [id], onDelete: Cascade)

  @@unique([sessionId, tutorId, studentId])
  @@index([studentId, status])
  @@map("student_reviews")
}

model Payment {
  createdAt         DateTime              @default(now()) @map("created_at")
  sessionId         String                @map("session_id")
  studentId         String                @map("student_id")
  tutorId           String                @map("tutor_id")
  amount            Decimal               @db.Decimal(10, 2)
  wompiId           String?               @map("wompi_id")
  id                String                @id @default(uuid())
  updatedAt         DateTime?             @updatedAt @map("updated_at")
  status            PaymentStatusEnum     @default(pending)
  tutorPayoutStatus TutorPayoutStatusEnum @default(pending) @map("tutor_payout_status")
  tutorPayoutAt     DateTime?             @map("tutor_payout_at")
  tutorPayoutNote   String?               @map("tutor_payout_note")
  tutorPayoutById   String?               @map("tutor_payout_by_id")
  session           Session               @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student           User                  @relation("PaymentsStudent", fields: [studentId], references: [id], onDelete: Cascade)
  tutor             User                  @relation("PaymentsTutor", fields: [tutorId], references: [id], onDelete: Cascade)

  @@index([tutorPayoutStatus, status])
  @@index([tutorId, tutorPayoutStatus])
  @@map("payments")
}

model PaymentIntent {
  id         String    @id @default(uuid())
  reference  String    @unique
  metadata   Json
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("payment_intents")
}

model TutorApplication {
  id              String                     @id @default(uuid())
  userId          String                     @map("user_id")
  reasonsToTeach  String                     @map("reasons_to_teach")
  subjects        String[]
  contactInfo     Json                       @map("contact_info")
  status          TutorApplicationStatusEnum @default(Pending)
  createdAt       DateTime                   @default(now()) @map("created_at")
  updatedAt       DateTime                   @updatedAt @map("updated_at")
  rejectionReason String?                    @map("rejection_reason")
  reviewedAt      DateTime?                  @map("reviewed_at")
  reviewedById    String?                    @map("reviewed_by_id")
  reviewedBy      User?                      @relation("ApplicationReviewedBy", fields: [reviewedById], references: [id])
  user            User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tutor_applications")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  sessionId String?  @map("session_id")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  session   Session? @relation(fields: [sessionId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

model AdminAuditLog {
  id         String   @id @default(uuid())
  adminId    String   @map("admin_id")
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  payload    Json?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")
  admin      User     @relation("AdminActor", fields: [adminId], references: [id])

  @@index([adminId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([targetType, targetId])
  @@map("admin_audit_log")
}

enum ComplexityEnum {
  Introductory
  Foundational
  Challenging
}

enum SessionTypeEnum {
  Individual
  Group
}

enum SessionStatusEnum {
  Pending
  Accepted
  Rejected
  Completed
  Canceled
}

enum LocationTypeEnum {
  Virtual
  Custom
}

enum TutorApplicationStatusEnum {
  Pending
  Approved
  Rejected
}

enum PaymentStatusEnum {
  pending
  paid
  failed
}

enum TutorPayoutStatusEnum {
  pending
  paid
}

enum ReviewStatusEnum {
  pending
  done
}

enum TutorCourseStatusEnum {
  Pending
  Approved
  Rejected
}

enum AuthProviderEnum {
  Local
  Google
}

enum Role {
  STUDENT
  ADMIN
}

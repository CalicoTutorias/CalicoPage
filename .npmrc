# pnpm configuration
# Resuelve automáticamente peer dependencies (evita ruido en este árbol)
auto-install-peers=true

# Seguridad: pnpm 10 NO ejecuta scripts de build de dependencias por defecto.
# Solo se ejecutan los aprobados en package.json -> pnpm.onlyBuiltDependencies
# Para revisar/aprobar nuevos: pnpm approve-builds
